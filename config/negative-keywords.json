{
  "_description": "Base negative keyword lists for Google Ads restaurant campaigns. Applied at launch to prevent wasted spend. All keywords are PHRASE match unless noted.",
  "_version": "1.0",
  "_updated": "2026-03-04",
  "_lessons": "Tres wasted $1,056/28% of spend on irrelevant searches before negatives were added. Cantina's PE campaign succeeded partly because of tight negative lists from day 1.",

  "base_restaurant": {
    "_description": "Applied to ALL restaurant campaigns regardless of type",
    "match_type": "PHRASE",
    "keywords": [
      "taco bell",
      "mcdonald's",
      "mcdonalds",
      "domino's",
      "dominos",
      "pizza hut",
      "burger king",
      "wendy's",
      "wendys",
      "chick-fil-a",
      "chick fil a",
      "chipotle",
      "subway",
      "kfc",
      "popeyes",
      "five guys",
      "in-n-out",
      "in n out",
      "panda express",
      "cheesecake factory",
      "olive garden",
      "applebees",
      "applebee's",
      "denny's",
      "dennys",
      "ihop",
      "jack in the box",
      "del taco",
      "wingstop",
      "raising cane's",
      "raising canes",
      "jobs",
      "careers",
      "hiring",
      "employment",
      "salary",
      "apply",
      "indeed",
      "glassdoor",
      "recipe",
      "how to make",
      "ingredients",
